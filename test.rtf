\f0\fs24 \cf0 CREATE TABLE ships (\
    SH_id INT PRIMARY KEY,\
    SH_name VARCHAR(100) NOT NULL,\
    SH_port VARCHAR(100) NOT NULL,\
    SH_discount DECIMAL(5,2) NOT NULL CHECK (SH_discount >= 0 AND SH_discount <= 100)\
);\
\
CREATE TABLE places (\
    PL_id INT PRIMARY KEY,\
    PL_port VARCHAR(100) NOT NULL,\
    PL_pier INT NOT NULL CHECK (PL_pier > 0),\
    PL_charges DECIMAL(5,2) NOT NULL CHECK (PL_charges >= 0 AND PL_charges <= 100),\
    UNIQUE (PL_port, PL_pier)\
);\
\
CREATE TABLE cargo (\
    C_id INT PRIMARY KEY,\
    C_name VARCHAR(100) NOT NULL,\
    C_port VARCHAR(100) NOT NULL,\
    C_price DECIMAL(15,2) NOT NULL CHECK (C_price >= 0),\
    C_maxnum INT NOT NULL CHECK (C_maxnum > 0)\
);\
\
CREATE TABLE loadings (\
    L_id INT PRIMARY KEY,\
    L_date DATE NOT NULL,\
    SH_id INT NOT NULL REFERENCES ships(SH_id),\
    PL_id INT NOT NULL REFERENCES places(PL_id),\
    C_id INT NOT NULL REFERENCES cargo(C_id),\
    L_cnum INT NOT NULL CHECK (L_cnum > 0)\
);\
\
