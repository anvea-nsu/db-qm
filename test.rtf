-- 1\
SELECT \
    s.SH_name,\
    p.PL_port,\
    p.PL_charges,\
    l.L_date\
FROM loadings l\
JOIN ships s USING(SH_id)\
JOIN places P USING(PL_id)\
WHERE p.PL_port != s.SH_port\
  AND p.PL_charges > 3\
ORDER BY l.L_date;\
\
\
\
-- 2\
SELECT \
    p.PL_port,\
    p.PL_pier\
FROM places p\
WHERE p.PL_id NOT IN (\
    SELECT DISTINCT l.PL_id\
    FROM loadings l\
    JOIN ships s USING(SH_id)\
    WHERE s.SH_port = '\uc0\u1058 \u1086 \u1082 \u1080 \u1086 '\
);\
\
\
\
-- 3\
SELECT DISTINCT \
    s.SH_id,\
    s.SH_name\
FROM ships s\
JOIN loadings l USING(SH_id)\
JOIN places p ON l.PL_id = p.PL_id\
WHERE p.PL_port IN ('\uc0\u1057 \u1077 \u1074 \u1072 \u1089 \u1090 \u1086 \u1087 \u1086 \u1083 \u1100 ', '\u1042 \u1083 \u1072 \u1076 \u1080 \u1074 \u1086 \u1089 \u1090 \u1086 \u1082 ')\
AND s.SH_discount < (SELECT AVG(SH_discount) FROM ships);\
\
\
\
-- 4\
SELECT \
    c.C_name,\
    SUM(l.L_cnum)\
FROM cargo c\
JOIN loadings l USING(C_id)\
GROUP BY c.C_id\
ORDER BY SUM(l.L_cnum) DESC;\
\
\
\
-- 5\
SELECT \
    s.SH_name,\
    s.SH_port,\
    ROUND(\
        l.L_cnum * c.C_price * \
        (1 - s.SH_discount / 100) * \
        (1 + p.PL_charges / 100), \
        2\
    ) as full_price\
FROM loadings l\
JOIN ships s USING(SH_id)\
JOIN places p USING(PL_id)\
JOIN cargo c USING(C_id)\
WHERE l.L_date BETWEEN '2025-06-11' AND '2025-09-21'\
ORDER BY (\
    l.L_cnum * c.C_price * \
    (1 - s.SH_discount / 100) * \
    (1 + p.PL_charges / 100)\
) DESC\
LIMIT 1;}